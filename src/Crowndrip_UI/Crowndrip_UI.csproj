<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net5.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>Resources\icon.ico</ApplicationIcon>
    <!-- 確保輸出檔案名稱為 Crowndrip -->
    <AssemblyName>Crowndrip</AssemblyName>
    <RootNamespace>Crowndrip_UI</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- 關鍵：引用你的 WeAreDevs API -->
    <Reference Include="wearedevs_exploit_api">
      <HintPath>..\..\lib\wearedevs_exploit_api.dll</HintPath>
      <!-- 設定編譯時自動複製到輸出目錄 -->
      <Private>True</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <!-- 確保圖示檔案會被包含在編譯中 -->
    <None Update="Resources\icon.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
